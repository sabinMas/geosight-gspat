NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token
# Cerebras — single key powers all AI features (analysis, agents, streaming)
# Get a key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key
# Optional: override default model (qwen-3-235b-a22b-instruct-2507) and
# response cap (600 tokens). Switch to llama3.1-8b for fastest streaming.
# CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
# CEREBRAS_MAX_TOKENS=600
# Set to "true" to enable RAG (adds ~750 input tokens + a Gemini embedding
# call per request). Off by default for cost/latency.
# RAG_ENABLED=false
# The following public APIs are used without keys:
# - USGS Groundwater Levels (waterservices.usgs.gov / api.waterdata.usgs.gov)
# - NRCS Soil Data Access (sdmdataaccess.nrcs.usda.gov)
# - USGS Seismic Design Maps (earthquake.usgs.gov)
# - Open-Meteo Historical Archive (archive-api.open-meteo.com)
# Used for: text-embedding-004 RAG embeddings only (RAG_ENABLED=true required)
# Note: Gemini is no longer used as an AI analysis fallback. Cerebras is the
# sole AI provider; without CEREBRAS_API_KEY the app falls back to deterministic mode.
GEMINI_API_KEY=your_gemini_api_key_optional
NASA_FIRMS_MAP_KEY=your_nasa_firms_map_key_optional
# NPS API — get a free key at https://www.nps.gov/subjects/developer/get-started.htm
NPS_API_KEY=your_nps_api_key
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
# Auth.js v5 — run `npx auth secret` to generate AUTH_SECRET
AUTH_SECRET=your_auth_secret_run_npx_auth_secret_to_generate
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret
AUTH_GITHUB_ID=your_github_oauth_app_id
AUTH_GITHUB_SECRET=your_github_oauth_app_secret
# Sentry error monitoring — get your DSN from sentry.io after creating a Next.js project
NEXT_PUBLIC_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_AUTH_TOKEN=your_sentry_auth_token_for_source_map_uploads
